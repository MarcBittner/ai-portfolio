# cycleledger — environment template. Copy to .env (gitignored) and edit.
# The app runs with ALL of these unset: offline LLM fallback + the local
# Postgres defaults in config/database.yml. Nothing here is required.

# --- data layer -----------------------------------------------------------
# Full Postgres connection string. Rails merges this on top of database.yml,
# so it is how the Docker image / Render wire to an external Postgres.
DATABASE_URL=postgresql://app:app@localhost:5432/cycleledger_development

# Or the discrete parts (used by database.yml defaults when DATABASE_URL unset):
# PGHOST=localhost
# PGPORT=5432
# PGUSER=app
# PGPASSWORD=app

# --- background jobs ------------------------------------------------------
# When set, Active Job uses the Sidekiq adapter and points at this Redis.
# When unset, IngestJob runs :inline (no worker / Redis needed).
# REDIS_URL=redis://localhost:6379/0
# SIDEKIQ_URL=redis://localhost:6379/0

# --- LLM router (all optional; absent => deterministic offline path) ------
# A provider is used only if its key is set; chain is paid -> local -> free.
LLM_MODE=auto                  # auto | paid | local | free | offline
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemma-4-31b-it:free
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# --- web server -----------------------------------------------------------
# PORT=8080
# RAILS_MAX_THREADS=5
