# llm-gateway runs fully offline with no .env at all: routing falls through to a
# deterministic mock provider, so every eval number reproduces with zero keys and
# zero cost. Set any of these to route completions to a real model. NEVER commit
# real keys; on a public host leave them unset (the gateway stays offline).

# --- Routing mode -----------------------------------------------------------
# auto (default) walks the full chain: paid → local → free → offline.
# Or pin a tier: paid | local | free | offline
# LLM_MODE=auto

# --- Paid providers (tried first in auto: Anthropic, then OpenAI) -----------
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# --- Local Ollama (autodetected via /api/tags; cost $0) ---------------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# --- Free providers (OpenRouter free-tier models) ---------------------------
# OPENROUTER_API_KEY=sk-or-your-key-here
# OPENROUTER_MODEL=google/gemma-4-31b-it:free
# OpenRouter caps the `models` fallback array at 3 entries.
# OPENROUTER_FREE_FALLBACKS=google/gemma-4-31b-it:free,nvidia/nemotron-3-super-120b-a12b:free,nvidia/nemotron-3-nano-30b-a3b:free

# --- Routing tunables -------------------------------------------------------
# LLM_TIMEOUT=45                 # per-request HTTP timeout, seconds
# LLM_BREAKER_THRESHOLD=3        # consecutive failures before a provider opens
# LLM_BREAKER_COOLDOWN=30        # seconds a provider stays skipped, then half-open

# --- Governance policy (all layers default ON; set to 0 to disable) ---------
# GATEWAY_FIREWALL_INPUT=1       # enforce the input firewall (block injections)
# GATEWAY_REDACT_INPUT=1         # redact PII/secrets before the provider sees them
# GATEWAY_FIREWALL_OUTPUT=1      # enforce the output firewall (block leaks)
# GATEWAY_REDACT_OUTPUT=1        # redact PII/secrets before returning/logging
# GATEWAY_AUDIT=1                # append every request to the hash-chained log
