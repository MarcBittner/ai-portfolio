# persona-twin configuration
# Copy to .env and fill in real values. Everything is OPTIONAL —
# with no .env at all, the app runs fully offline (in-memory vector
# store + deterministic mock LLM + hash-based embeddings).

# --- LLM providers (either, both, or neither) ---
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here

# --- MongoDB Atlas (omit to use the in-memory vector store) ---
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net
# MONGODB_DB=persona_twin
# MONGODB_VECTOR_INDEX=persona_chunks_index

# --- Redis cache (omit to use the in-process cache) ---
# REDIS_URL=redis://localhost:6379/0

# --- Behavior overrides ---
# Force mock mode even when API keys are present (useful for tests/CI)
# PERSONA_TWIN_MOCK=1
# Routing preference: cost | latency | quality
# PERSONA_TWIN_ROUTE_OBJECTIVE=cost

# --- Ollama (local models; discovered at startup, cost $0) ---
# OLLAMA_BASE_URL=http://localhost:11434

# --- OpenRouter free-model discovery (on by default when key is set) ---
# PERSONA_TWIN_OPENROUTER_FREE=0

# --- Any other OpenAI-compatible service (Groq, Gemini, Cerebras, ...) ---
# See docs/free-models.md for ready-made entries. Keys live in their own
# env vars; this JSON never contains secrets.
# PERSONA_TWIN_EXTRA_PROVIDERS='[{"name":"groq","base_url":"https://api.groq.com/openai/v1","api_key_env":"GROQ_API_KEY","models":[{"id":"llama-3.3-70b-versatile","quality":7,"speed":10}]}]'
# GROQ_API_KEY=...
