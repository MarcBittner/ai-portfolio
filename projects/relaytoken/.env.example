# relaytoken runs fully offline with no .env at all: the security core (mint /
# verify / adversary) never needs a network call, and the LLM routing chain for
# the grant explainer falls through to a deterministic narrator. Set any of these
# to route the grant explanation to a real model. NEVER commit real keys; on a
# public host leave them unset (offline).

# --- Routing mode -----------------------------------------------------------
# auto (default) walks the full chain; or pin a tier: paid | local | free | offline
# LLM_MODE=auto

# --- Paid providers (tried first in auto) -----------------------------------
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# --- Local Ollama (autodetected via /api/tags; cost $0) ---------------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# --- Free providers (OpenRouter free-tier models) ---------------------------
# OPENROUTER_API_KEY=sk-or-your-key-here
# OPENROUTER_MODEL=google/gemma-4-31b-it:free

# --- Token signing (HS256) --------------------------------------------------
# The mint/verify signing key. Defaults to a non-secret demo key so the service
# runs out of the box; set a real, high-entropy secret in any real deployment.
# RELAYTOKEN_API_KEY=relaytoken-demo-key
# RELAYTOKEN_API_SECRET=change-me-to-a-long-random-secret

# --- Server -----------------------------------------------------------------
# PORT=8080
