# rtc-guard runs fully offline with no .env at all: the LLM routing chain falls
# through to a deterministic rule-based grant auditor, so every number reproduces
# with zero keys and zero cost. The security core (token mint/verify + the
# adversarial suite) is deterministic and needs no keys regardless. Set any of
# these to route the grant auditor to a real model. NEVER commit real keys; on a
# public host leave them unset (offline).

# --- Routing mode -----------------------------------------------------------
# auto (default) walks the full chain; or pin a tier: paid | local | free | offline
# LLM_MODE=auto

# --- Paid providers (tried first in auto) -----------------------------------
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# --- Local Ollama (autodetected via /api/tags; cost $0) ---------------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# --- Free providers (OpenRouter free-tier models) ---------------------------
# OPENROUTER_API_KEY=sk-or-your-key-here
# OPENROUTER_MODEL=google/gemma-4-31b-it:free

# --- Token signing key (HS256 demo key for mint/verify) ---------------------
# A demo default is used if unset; mints only throwaway tokens, no real secret.
# RTC_GUARD_SIGNING_KEY=rtc-guard-demo-signing-key-v1
