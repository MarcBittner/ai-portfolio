# ============================================
# Tanglement.ai Teaser Site - Environment Variables
# ============================================
#
# This file contains example environment variables for the teaser site.
# Copy this file to .env.local for local development.
#
# IMPORTANT:
# - Never commit .env.local or .env.production to version control
# - Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# - Server-side variables are only available in API routes and server components
#
# ============================================

# --------------------------------------------
# Application Environment
# --------------------------------------------
# Values: development, production, test
NODE_ENV=development

# Public site URL (exposed to browser)
# Development: http://localhost:3000
# Production: https://tanglement.ai
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server port (optional, defaults to 3000)
PORT=3000

# --------------------------------------------
# Database (PostgreSQL)
# --------------------------------------------
# Format: postgresql://user:password@host:port/database
# Leave empty to disable database features
DATABASE_URL=

# Example for local development:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/tanglement

# Example for production:
# DATABASE_URL=postgresql://user:password@db.example.com:5432/tanglement_prod

# --------------------------------------------
# Email Service (SendGrid)
# --------------------------------------------
# Get your API key from: https://app.sendgrid.com/settings/api_keys
# Leave empty to disable email features
SENDGRID_API_KEY=

# From email address for transactional emails
SENDGRID_FROM_EMAIL=hello@tanglement.ai

# From name for transactional emails
SENDGRID_FROM_NAME=Tanglement.ai

# --------------------------------------------
# Email Marketing (ConvertKit)
# --------------------------------------------
# Get your API credentials from: https://app.convertkit.com/account_settings/advanced_settings
# Leave empty to disable email marketing features
CONVERTKIT_API_KEY=
CONVERTKIT_API_SECRET=

# ConvertKit form ID for waitlist signups
# Find this in your ConvertKit form settings
CONVERTKIT_FORM_ID=

# Optional: ConvertKit tag ID to apply to new subscribers
CONVERTKIT_TAG_ID=

# --------------------------------------------
# Analytics (Plausible)
# --------------------------------------------
# Your domain for Plausible analytics
# Leave empty to disable analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Example:
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=tanglement.ai

# --------------------------------------------
# Error Tracking (Sentry)
# --------------------------------------------
# Get your DSN from: https://sentry.io/settings/projects/
# Leave empty to disable error tracking

# Server-side error tracking
SENTRY_DSN=

# Client-side error tracking (exposed to browser)
NEXT_PUBLIC_SENTRY_DSN=

# Example:
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# --------------------------------------------
# Development Only
# --------------------------------------------
# These variables are only used in development mode

# Disable telemetry in Next.js
# NEXT_TELEMETRY_DISABLED=1

# Enable verbose logging
# DEBUG=true
