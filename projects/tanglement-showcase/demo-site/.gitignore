# Tanglement.ai Teaser Site - .gitignore Template
# Copy this to your project root as .gitignore when initializing the Next.js project

# ============================================
# Dependencies
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# Next.js
# ============================================
.next/
out/
build/
dist/
.vercel
.netlify

# Next.js cache
.next/cache/

# Production build
/build

# ============================================
# Environment Variables
# ============================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Keep example file
!.env.example

# ============================================
# Testing
# ============================================
coverage/
.nyc_output/
*.lcov

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Jest
jest-coverage/

# ============================================
# IDEs and Editors
# ============================================
# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
.\#*

# ============================================
# Operating System Files
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ============================================
# TypeScript
# ============================================
*.tsbuildinfo
next-env.d.ts

# ============================================
# Database
# ============================================
*.db
*.sqlite
*.sqlite3
/postgres-data/
/mysql-data/

# ============================================
# Temporary Files
# ============================================
tmp/
temp/
*.tmp
*.temp
*.cache

# ============================================
# Security & Secrets
# ============================================
# Never commit these!
*.pem
*.key
*.cert
*.crt
.ssh/
.gnupg/
secrets/
credentials/

# API keys and secrets
.env.secrets
secrets.json
credentials.json

# ============================================
# Spec-driven workflow — untracked session data
# ============================================
# Holds credentials.md, session transcripts, and the deploy SSH key
# (ghostlocalhost.pem). NEVER commit anything under this directory.
docs/spec/untracked/

# ============================================
# Build Artifacts
# ============================================
.turbo/
.cache/
.parcel-cache/
.docusaurus/

# ============================================
# Miscellaneous
# ============================================
# Sentry
.sentryclirc

# Storybook
storybook-static/
.storybook/build/

# TypeScript incremental compilation
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Optional Prisma files (if using Prisma ORM)
prisma/*.db
prisma/*.db-journal
prisma/migrations/**/migration.sql

# Terraform (if used for infrastructure)
.terraform/
*.tfstate
*.tfstate.backup

# Docker
.dockerignore
docker-compose.override.yml

# ============================================
# Keep These Files
# ============================================
# Ensure these are tracked even if they match patterns above
!.gitkeep
!.gitignore
!.env.example
!.vscode/settings.json
!.github/

# ============================================
# Project-Specific
# ============================================
# Add any project-specific ignores below

# Local development database
/local-db/

# Generated documentation
/docs/generated/

# Analytics data
/analytics-data/

# User uploads (if applicable)
/public/uploads/

# Email templates compiled (if using email builder)
/emails/compiled/
