# ---- Convex (managed backend) ----
# Set automatically by `npx convex dev` / `npx convex deploy`.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# ---- Clerk (auth + orgs + billing) ----
# From dashboard.clerk.com. Enable Email + Organizations, and add a JWT
# template named "convex" (one-click in Clerk → JWT Templates → Convex).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Your Clerk Frontend API URL / issuer, e.g. https://your-slug.clerk.accounts.dev
# Used by convex/auth.config.ts to validate Clerk JWTs.
CLERK_JWT_ISSUER_DOMAIN=

# ---- LLM (server-side only; set in the Convex deployment, not the browser) ----
# Pick ONE. With none set, extraction falls back to a deterministic mock so the
# app still runs end-to-end with zero keys / zero cost.
#   Anthropic = the paid path (best quality):
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
#   OpenRouter = free models (default for the public demo):
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free
